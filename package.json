{
  "name": "agent-marko-hermes",
  "private": true,
  "version": "0.1.0",
  "description": "Agent-Marko UI + Hermes Agent backend — one-hop, no Bun middle layer",
  "type": "module",
  "workspaces": [
    "ui",
    "packages/*"
  ],
