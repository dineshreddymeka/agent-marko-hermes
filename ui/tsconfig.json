{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "noEmit": true,
    "plugins": [{ "name": "next" }],
    "allowJs": true,
    "incremental": true,
    "paths": {
      "@app/*": ["./src/*"],
      "@shared/*": ["../packages/shared/src/*"],
      "@hermes/shared": ["../packages/shared/src/index.ts"]
    }
  },
  "include": [
    "next-env.d.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/routeTree.gen.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
